# =============================================================================
# CyberAsk Nessus Mock — Play Store review demo instance
# Copy to .env and adjust. Never commit real secrets.
# =============================================================================

# HTTP port exposed by the container / local server
PORT=8834

# Bind address inside container (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# SQLite database path (Docker Compose sets /data/nessus_mock.db on a volume)
DATABASE_PATH=./data/nessus_mock.db

# Set to 1 to wipe and re-seed demo data on every start (dev only)
RESET_DB_ON_START=0

# Automatic wipe + reseed interval in hours (0 = disabled). Default 6 for Play demo hygiene.
RESEED_INTERVAL_HOURS=6

# API credentials the Android app must use (Settings → Access Key / Secret Key)
# Reviewer credentials for Play Console data safety / login review:
NESSUS_ACCESS_KEY=demo-access-key-reviewer
NESSUS_SECRET_KEY=demo-secret-key-reviewer

# Optional second pair (comma-separated parallel lists if you add more)
# EXTRA_ACCESS_KEYS=
# EXTRA_SECRET_KEYS=

# Mock data volume (defaults match a rich demo for review)
NUM_SCANS=10
NUM_GROUPS=10
NUM_AGENT_GROUPS=10
AGENTS_PER_GROUP=10
NUM_UNLINKED_AGENTS=15
NUM_HOSTS_PER_SCAN=8
NUM_VULNS_PER_HOST=12
NUM_HISTORY_PER_SCAN=3
NUM_SCANNERS=3
NUM_TEMPLATES=8

# Export: seconds before status becomes "ready" (0 = immediate)
EXPORT_READY_SECONDS=2

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Flask
FLASK_DEBUG=0
